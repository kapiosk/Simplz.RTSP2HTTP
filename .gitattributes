# Normalize line endings: LF in the repo, auto on checkout.
* text=auto eol=lf

# Scripts / configs that must stay LF (used inside Linux containers).
*.sh        text eol=lf
Dockerfile  text eol=lf
Caddyfile   text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
.env*       text eol=lf

# Windows-specific
*.ps1       text eol=crlf

# Treat these as binary (no diff/eol munging).
*.png       binary
*.jpg       binary
*.ico       binary
*.ts        binary
